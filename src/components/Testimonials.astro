---
interface Testimonial {
  clientName: string;
  clientTitle?: string;
  quote: string;
  rating: number;
  projectType?: string;
  country?: string;
}

interface Stats {
  jobSuccess?: string;
  rating?: string;
  projectsDelivered?: string;
  happyClients?: string;
  upworkUrl?: string;
  testimonialsHeading?: string;
  testimonialsSubheading?: string;
}

interface Props {
  testimonials: Testimonial[];
  stats?: Stats;
}

const { testimonials, stats } = Astro.props;

// Duplicate for seamless infinite scroll
const row1 = [...testimonials, ...testimonials];
const row2 = [...testimonials.slice().reverse(), ...testimonials.slice().reverse()];
const verticalCol = [...testimonials, ...testimonials];
---

<section class="testimonials relative py-24 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent-500/5 rounded-full blur-[128px] animate-glow-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500/5 rounded-full blur-[128px] animate-glow-pulse" style="animation-delay: 1.5s;"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 mb-16 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-upwork-500/20 bg-upwork-500/5 mb-6">
      <svg class="w-4 h-4 text-upwork-500" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.548-1.405-.002-2.543-1.143-2.545-2.548V3.492H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-1.19c.529 1.107 1.182 2.229 1.974 3.221l-1.673 7.873h2.797l1.213-5.71c1.063.679 2.285 1.109 3.686 1.109 3 0 5.439-2.452 5.439-5.45 0-3-2.439-5.439-5.439-5.439z"/>
      </svg>
      <span class="text-xs font-medium text-upwork-400">Top Rated on Upwork</span>
    </div>

    <h2 class="testimonial-heading text-3xl md:text-5xl font-bold text-dark-50 mb-4">
      {stats?.testimonialsHeading || 'Clients love working with me'}
    </h2>
    <p class="testimonial-subheading text-dark-400 max-w-xl mx-auto">
      {stats?.testimonialsSubheading || "Don't take my word for it — here's what clients say after working together."}
    </p>

    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-10">
      <div class="text-center">
        <div class="text-3xl font-bold text-upwork-400">{stats?.jobSuccess || '100%'}</div>
        <div class="testimonial-stat-label text-xs text-dark-500 mt-1">Job Success</div>
      </div>
      <div class="text-center">
        <div class="testimonial-stat-value text-3xl font-bold text-dark-50">{stats?.rating || '5.0'}</div>
        <div class="text-xs text-dark-500 mt-1 flex items-center gap-1">
          <span>Rating</span>
          <div class="flex">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
        </div>
      </div>
      <div class="text-center">
        <div class="testimonial-stat-value text-3xl font-bold text-dark-50">{stats?.projectsDelivered || '20+'}</div>
        <div class="testimonial-stat-label text-xs text-dark-500 mt-1">Projects Delivered</div>
      </div>
      <div class="text-center">
        <div class="testimonial-stat-value text-3xl font-bold text-dark-50">{stats?.happyClients || '10+'}</div>
        <div class="testimonial-stat-label text-xs text-dark-500 mt-1">Happy Clients</div>
      </div>
    </div>
  </div>

  <!-- Mobile: single vertical scrolling rail -->
  <div class="md:hidden relative h-[420px] overflow-hidden px-4">
    <div class="absolute top-0 left-0 right-0 h-16 bg-gradient-to-b from-dark-950 to-transparent z-10"></div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-dark-950 to-transparent z-10"></div>

    <div class="animate-marquee-vertical will-change-transform flex flex-col gap-3">
      {verticalCol.map((t) => (
        <div class="rounded-2xl border border-dark-800/60 bg-dark-900/40 p-5">
          <svg class="w-6 h-6 text-accent-500/20 mb-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.998 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z"/>
          </svg>

          <p class="text-dark-300 text-sm leading-relaxed mb-4 line-clamp-4">
            "{t.quote}"
          </p>

          <div class="flex items-center justify-between">
            <div>
              <div class="text-sm font-semibold text-dark-100">{t.clientName}</div>
              {t.clientTitle && (
                <div class="text-xs text-dark-500 mt-0.5">{t.clientTitle}</div>
              )}
            </div>
            <div class="flex items-center gap-1.5">
              {t.projectType && (
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-dark-800 text-dark-400 border border-dark-700">
                  {t.projectType}
                </span>
              )}
              <div class="flex">
                {Array.from({ length: t.rating }).map(() => (
                  <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Desktop: two horizontal marquee rows -->
  <div class="hidden md:block">
    <div class="relative mb-6">
      <div class="testimonial-fade absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-dark-950 to-transparent z-10"></div>
      <div class="testimonial-fade absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-dark-950 to-transparent z-10"></div>

      <div class="flex animate-marquee will-change-transform hover:[animation-play-state:paused]">
        {row1.map((t) => (
          <div class="testimonial-card flex-shrink-0 w-[380px] mx-3">
            <div class="relative group h-full flex flex-col rounded-2xl border border-dark-800/60 bg-dark-900/40 p-6 transition-colors duration-300 hover:border-dark-600 hover:bg-dark-800/60">

              <svg class="w-8 h-8 text-accent-500/20 mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.998 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z"/>
              </svg>

              <p class="text-dark-300 text-sm leading-relaxed mb-6 line-clamp-4 flex-grow">
                "{t.quote}"
              </p>

              <div class="flex items-center justify-between mt-auto">
                <div>
                  <div class="text-sm font-semibold text-dark-100">{t.clientName}</div>
                  {t.clientTitle && (
                    <div class="text-xs text-dark-500 mt-0.5">{t.clientTitle}</div>
                  )}
                </div>
                <div class="flex items-center gap-1.5">
                  {t.projectType && (
                    <span class="text-[10px] px-2 py-0.5 rounded-full bg-dark-800 text-dark-400 border border-dark-700">
                      {t.projectType}
                    </span>
                  )}
                  <div class="flex">
                    {Array.from({ length: t.rating }).map(() => (
                      <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>
                </div>
              </div>

              {t.country && (
                <div class="absolute top-4 right-4 text-[10px] text-dark-50">{t.country}</div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="relative">
      <div class="testimonial-fade absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-dark-950 to-transparent z-10"></div>
      <div class="testimonial-fade absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-dark-950 to-transparent z-10"></div>

      <div class="flex animate-marquee-reverse will-change-transform hover:[animation-play-state:paused]">
        {row2.map((t) => (
          <div class="testimonial-card flex-shrink-0 w-[380px] mx-3">
            <div class="relative group h-full flex flex-col rounded-2xl border border-dark-800/60 bg-dark-900/40 p-6 transition-colors duration-300 hover:border-dark-600 hover:bg-dark-800/60">

              <svg class="w-8 h-8 text-cyan-500/20 mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.998 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z"/>
              </svg>

              <p class="text-dark-300 text-sm leading-relaxed mb-6 line-clamp-4 flex-grow">
                "{t.quote}"
              </p>

              <div class="flex items-center justify-between mt-auto">
                <div>
                  <div class="text-sm font-semibold text-dark-100">{t.clientName}</div>
                  {t.clientTitle && (
                    <div class="text-xs text-dark-500 mt-0.5">{t.clientTitle}</div>
                  )}
                </div>
                <div class="flex items-center gap-1.5">
                  {t.projectType && (
                    <span class="text-[10px] px-2 py-0.5 rounded-full bg-dark-800 text-dark-400 border border-dark-700">
                      {t.projectType}
                    </span>
                  )}
                  <div class="flex">
                    {Array.from({ length: t.rating }).map(() => (
                      <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>
                </div>
              </div>

              {t.country && (
                <div class="absolute top-4 right-4 text-[10px] text-dark-50">{t.country}</div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 mt-14 text-center">
    <a
      href={stats?.upworkUrl || "https://www.upwork.com/freelancers/~014d8d3df9f96bac7f"}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-upwork-500/30 bg-upwork-500/10 text-upwork-400 text-sm font-medium hover:bg-upwork-500/20 hover:border-upwork-500/50 transition-all duration-300 hover:shadow-lg hover:shadow-upwork-500/10"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.548-1.405-.002-2.543-1.143-2.545-2.548V3.492H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-1.19c.529 1.107 1.182 2.229 1.974 3.221l-1.673 7.873h2.797l1.213-5.71c1.063.679 2.285 1.109 3.686 1.109 3 0 5.439-2.452 5.439-5.45 0-3-2.439-5.439-5.439-5.439z"/>
      </svg>
      View my Upwork profile
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
      </svg>
    </a>
  </div>
</section>
