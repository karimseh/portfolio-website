---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  [key: string]: any;
}

const { variant = 'primary', size = 'md', href, class: className, ...rest } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 cursor-pointer';

const variants = {
  primary: 'bg-accent-500 text-white hover:bg-accent-600 shadow-lg shadow-accent-500/20',
  secondary: 'border border-dark-600 text-dark-200 hover:bg-dark-800 hover:border-dark-500',
  ghost: 'text-dark-400 hover:text-dark-100 hover:bg-dark-800',
};

const sizes = {
  sm: 'text-sm px-3 py-1.5',
  md: 'text-sm px-5 py-2.5',
  lg: 'text-base px-7 py-3',
};

const classes = [baseClasses, variants[variant], sizes[size], className].join(' ');
const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={classes} {...rest}>
  <slot />
</Tag>
