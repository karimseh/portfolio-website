---
interface Props {
  variant?: 'default' | 'outline';
  size?: 'sm' | 'md';
  class?: string;
}

const { variant = 'default', size = 'md', class: className } = Astro.props;

const variants = {
  default: 'bg-dark-800 text-dark-300',
  outline: 'border border-dark-600 text-dark-400',
};

const sizes = {
  sm: 'text-xs px-2 py-0.5',
  md: 'text-xs px-2.5 py-1',
};
---

<span class:list={['rounded-full font-medium', variants[variant], sizes[size], className]}>
  <slot />
</span>
