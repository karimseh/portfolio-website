<form id="contact-form" class="space-y-6">
  <div>
    <label for="name" class="block text-sm font-medium text-dark-300 mb-2">Name</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-4 py-3 bg-dark-900 border border-dark-700 rounded-lg text-dark-100 placeholder-dark-500 focus:outline-none focus:border-accent-500 focus:ring-1 focus:ring-accent-500 transition-colors"
      placeholder="Your name"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-dark-300 mb-2">Email</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 bg-dark-900 border border-dark-700 rounded-lg text-dark-100 placeholder-dark-500 focus:outline-none focus:border-accent-500 focus:ring-1 focus:ring-accent-500 transition-colors"
      placeholder="you@example.com"
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-dark-300 mb-2">Message</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full px-4 py-3 bg-dark-900 border border-dark-700 rounded-lg text-dark-100 placeholder-dark-500 focus:outline-none focus:border-accent-500 focus:ring-1 focus:ring-accent-500 transition-colors resize-none"
      placeholder="Tell me about your project..."
    ></textarea>
  </div>

  <div>
    <button
      type="submit"
      id="submit-btn"
      class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-accent-500 text-white font-medium text-sm px-8 py-3 rounded-lg hover:bg-accent-600 transition-all duration-200 shadow-lg shadow-accent-500/20 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Send Message
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </button>
  </div>

  <p id="form-status" class="text-sm hidden"></p>
</form>

<script>
  import emailjs from '@emailjs/browser';

  const SITE_KEY = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
  const VERIFY_URL = import.meta.env.PUBLIC_RECAPTCHA_VERIFY_URL;

  // Load reCAPTCHA on page load so Google can observe user behavior
  const recaptchaScript = document.createElement('script');
  recaptchaScript.src = `https://www.google.com/recaptcha/api.js?render=${SITE_KEY}`;
  recaptchaScript.async = true;
  document.head.appendChild(recaptchaScript);

  function getRecaptchaToken(): Promise<string> {
    return new Promise((resolve, reject) => {
      grecaptcha.ready(() => {
        grecaptcha.execute(SITE_KEY, { action: 'contact_form' }).then(resolve).catch(reject);
      });
    });
  }

  async function verifyRecaptcha(token: string): Promise<boolean> {
    const response = await fetch(VERIFY_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token }),
    });
    if (!response.ok) return false;
    const data = await response.json();
    return data.success === true;
  }

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    submitBtn.disabled = true;

    if (status) {
      status.textContent = 'Verifying...';
      status.className = 'text-sm text-dark-400';
      status.classList.remove('hidden');
    }

    try {
      const token = await getRecaptchaToken();
      const isHuman = await verifyRecaptcha(token);

      if (!isHuman) {
        if (status) {
          status.textContent = 'Verification failed. Please try again or email me directly.';
          status.className = 'text-sm text-red-400';
        }
        submitBtn.disabled = false;
        return;
      }

      if (status) {
        status.textContent = 'Sending...';
      }

      await emailjs.send(
        import.meta.env.PUBLIC_EMAILJS_SERVICE_ID,
        import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID,
        {
          name: formData.get('name'),
          email: formData.get('email'),
          message: formData.get('message'),
        },
        import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY,
      );

      if (status) {
        status.textContent = "Message sent! I'll get back to you soon.";
        status.className = 'text-sm text-green-400';
      }
      form.reset();
    } catch {
      if (status) {
        status.textContent = 'Something went wrong. Please try emailing me directly.';
        status.className = 'text-sm text-red-400';
      }
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
