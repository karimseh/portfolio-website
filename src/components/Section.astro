---
interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className } = Astro.props;
---

<section class:list={['max-w-6xl mx-auto px-6 py-20', className]}>
  {title && (
    <div class="mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-dark-50">{title}</h2>
      {subtitle && <p class="mt-2 text-dark-400">{subtitle}</p>}
    </div>
  )}
  <slot />
</section>
